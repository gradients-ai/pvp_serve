# --- Model serving ---
# OpenAI-compatible endpoint serving the champion model (e.g. SGLang).
PVP_SGLANG_BASE_URL=http://localhost:30000/v1
# Model name as registered in the inference server (SGLang: the --served-model-name
# or the model path). Must match what the server reports.
PVP_INFERENCE_MODEL=champion
# Optional sampling controls for the champion's turns.
PVP_TEMPERATURE=0.0
PVP_SEED=0

# --- Agent mode ---
# 'llm'    -> play against the served champion model (production)
# 'random' -> agent plays uniformly-random legal moves (no GPU needed; for local
#             dev / testing the full session + rendering loop without a model)
PVP_AGENT_KIND=llm

# --- G.O.D source ---
# Where to import core.pvp from. Resolution order: this var -> ./god (submodule)
# -> ../G.O.D (sibling checkout).
# GOD_REPO_PATH=/abs/path/to/G.O.D

# --- HTTP ---
PVP_HOST=0.0.0.0
PVP_PORT=8000
# Comma-separated allowed CORS origins for the browser (the gradients-web site).
PVP_CORS_ORIGINS=https://gradients.io,http://localhost:5173
